{
  "meta": {
    "id": "bfi-2-j-student",
    "name": "BFI-2-J（大学生規準）",
    "short_name": "BFI-2-J（大学生）",
    "description": "Big Five Inventory-2の日本語版。5つのドメイン（外向性・協調性・勤勉性・否定的情動性・開放性）と各3つのファセット（計15）を測定する。規準値：大学生サンプル（N=487）。",
    "source": "Yoshino et al. (2022)",
    "apa_citation": "Yoshino, S., Shimotsukasa, T., Oshio, A., Hashimoto, Y., Ueno, Y., Mieda, T., Migiwa, I., Sato, T., Kawamoto, S., Soto, C. J., & John, O. P. (2022). A validation of the Japanese adaptation of the Big Five Inventory-2 (BFI-2-J). Frontiers in Psychology, 13, 924351. https://doi.org/10.3389/fpsyg.2022.924351",
    "doi": "10.3389/fpsyg.2022.924351",
    "target": "大学生",
    "language": "ja",
    "tags": ["パーソナリティ", "ビッグファイブ", "外向性", "協調性", "勤勉性", "神経症傾向", "開放性", "ファセット", "BFI-2"]
  },
  "instructions": "以下の項目についてあなたにどの程度あてはまるか，最も近いと思う数字を選んでください。私は...",
  "response_options": [
    { "value": 1, "label": "全くあてはまらない" },
    { "value": 2, "label": "あてはまらない" },
    { "value": 3, "label": "どちらともいえない" },
    { "value": 4, "label": "あてはまる" },
    { "value": 5, "label": "とてもよくあてはまる" }
  ],
  "items": [
    { "id": 1,  "text": "積極的で，社交的である。", "subscale": "sociability", "reverse": false },
    { "id": 2,  "text": "思いやりがあり，優しい。", "subscale": "compassion", "reverse": false },
    { "id": 3,  "text": "行き当たりばったりな方だ。", "subscale": "organization", "reverse": true },
    { "id": 4,  "text": "リラックスしていて，ストレスにうまく対処している。", "subscale": "anxiety", "reverse": true },
    { "id": 5,  "text": "芸術的関心があまりない。", "subscale": "aesthetic-sensitivity", "reverse": true },
    { "id": 6,  "text": "積極的な性格だ。", "subscale": "assertiveness", "reverse": false },
    { "id": 7,  "text": "礼儀正しく，他人に敬意をもって接する。", "subscale": "respectfulness", "reverse": false },
    { "id": 8,  "text": "だらだらと過ごす方だ。", "subscale": "productiveness", "reverse": true },
    { "id": 9,  "text": "失敗を経験しても楽天的なままでいる。", "subscale": "depression", "reverse": true },
    { "id": 10, "text": "色々な物事に対する好奇心が強い。", "subscale": "intellectual-curiosity", "reverse": false },
    { "id": 11, "text": "めったに興奮したり，熱狂したりしない。", "subscale": "energy-level", "reverse": true },
    { "id": 12, "text": "他人の欠点を見つけ出す方だ。", "subscale": "trust", "reverse": true },
    { "id": 13, "text": "しっかりしていて，真面目だ。", "subscale": "responsibility", "reverse": false },
    { "id": 14, "text": "不機嫌になりやすく，感情の起伏が激しい。", "subscale": "emotional-volatility", "reverse": false },
    { "id": 15, "text": "創意工夫が得意で，うまい方法を思いつくことができる。", "subscale": "creative-imagination", "reverse": false },
    { "id": 16, "text": "無口な方だ。", "subscale": "sociability", "reverse": true },
    { "id": 17, "text": "他人のことを思って心が痛むことはほとんどない。", "subscale": "compassion", "reverse": true },
    { "id": 18, "text": "几帳面で，規則正しく整えることが好きだ。", "subscale": "organization", "reverse": false },
    { "id": 19, "text": "神経が張り詰めることがある。", "subscale": "anxiety", "reverse": false },
    { "id": 20, "text": "芸術，音楽，文学に魅了されている。", "subscale": "aesthetic-sensitivity", "reverse": false },
    { "id": 21, "text": "上に立つ方で，リーダーとして活動する。", "subscale": "assertiveness", "reverse": false },
    { "id": 22, "text": "他人と言い争いを始める。", "subscale": "respectfulness", "reverse": true },
    { "id": 23, "text": "なかなか作業に取り掛かることができない。", "subscale": "productiveness", "reverse": true },
    { "id": 24, "text": "安心感を抱いており，心地よい。", "subscale": "depression", "reverse": true },
    { "id": 25, "text": "知的で哲学的な考察を避けるようにしている。", "subscale": "intellectual-curiosity", "reverse": true },
    { "id": 26, "text": "他の人と比べて活発ではない。", "subscale": "energy-level", "reverse": true },
    { "id": 27, "text": "他人を大目に見る寛大な人間だ。", "subscale": "trust", "reverse": false },
    { "id": 28, "text": "少し不注意なところがある。", "subscale": "responsibility", "reverse": true },
    { "id": 29, "text": "情緒が安定しており，簡単には取り乱さない。", "subscale": "emotional-volatility", "reverse": true },
    { "id": 30, "text": "創造性がほとんどない。", "subscale": "creative-imagination", "reverse": true },
    { "id": 31, "text": "内気なところがあり，内向的である。", "subscale": "sociability", "reverse": true },
    { "id": 32, "text": "進んで手伝おうとし，他人の利益を優先する。", "subscale": "compassion", "reverse": false },
    { "id": 33, "text": "物事をきれいに揃えたりまとめたりする。", "subscale": "organization", "reverse": false },
    { "id": 34, "text": "多くの悩みごとを抱えている。", "subscale": "anxiety", "reverse": false },
    { "id": 35, "text": "芸術と美を重視する。", "subscale": "aesthetic-sensitivity", "reverse": false },
    { "id": 36, "text": "人々の行動を左右するような影響力をもつことは難しいと感じる。", "subscale": "assertiveness", "reverse": true },
    { "id": 37, "text": "他人を見下すことがある。", "subscale": "respectfulness", "reverse": true },
    { "id": 38, "text": "手際よく行動し，物事を最後までやり遂げる。", "subscale": "productiveness", "reverse": false },
    { "id": 39, "text": "よく悲しい気分になる。", "subscale": "depression", "reverse": false },
    { "id": 40, "text": "考え方が複雑で，深く考える人間だ。", "subscale": "intellectual-curiosity", "reverse": false },
    { "id": 41, "text": "活力にあふれている。", "subscale": "energy-level", "reverse": false },
    { "id": 42, "text": "他人が考えていることを怪しんで不信感を抱く。", "subscale": "trust", "reverse": true },
    { "id": 43, "text": "ちゃんとしていて，いつも周りから当てにされる。", "subscale": "responsibility", "reverse": false },
    { "id": 44, "text": "自分の感情をコントロールしている。", "subscale": "emotional-volatility", "reverse": true },
    { "id": 45, "text": "ものごとを自由に心に思い描くのは難しい。", "subscale": "creative-imagination", "reverse": true },
    { "id": 46, "text": "おしゃべりな方だ。", "subscale": "sociability", "reverse": false },
    { "id": 47, "text": "冷淡で思いやりに欠けることがある。", "subscale": "compassion", "reverse": true },
    { "id": 48, "text": "乱雑なものはそのままにして，きれいにしない。", "subscale": "organization", "reverse": true },
    { "id": 49, "text": "不安や恐れを感じることはめったにない。", "subscale": "anxiety", "reverse": true },
    { "id": 50, "text": "詩や演劇をつまらないと思う。", "subscale": "aesthetic-sensitivity", "reverse": true },
    { "id": 51, "text": "他の人にリーダーシップを発揮してもらうほうが良いと思う。", "subscale": "assertiveness", "reverse": true },
    { "id": 52, "text": "他人に丁寧で，礼儀正しい。", "subscale": "respectfulness", "reverse": false },
    { "id": 53, "text": "根気強く，与えられた課題が終わるまで取り組む。", "subscale": "productiveness", "reverse": false },
    { "id": 54, "text": "憂うつになり，落胆する方だ。", "subscale": "depression", "reverse": false },
    { "id": 55, "text": "抽象的な知識にはほとんど関心がない。", "subscale": "intellectual-curiosity", "reverse": true },
    { "id": 56, "text": "情熱を大いに表に出す。", "subscale": "energy-level", "reverse": false },
    { "id": 57, "text": "人々のいちばん良いところを思い浮かべる。", "subscale": "trust", "reverse": false },
    { "id": 58, "text": "無責任な行動をしてしまうことがある。", "subscale": "responsibility", "reverse": true },
    { "id": 59, "text": "神経質で，感情的になりやすい。", "subscale": "emotional-volatility", "reverse": false },
    { "id": 60, "text": "個性的で，新しいアイディアを思いつく。", "subscale": "creative-imagination", "reverse": false }
  ],
  "subscales": [
    {
